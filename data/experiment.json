  "procedure": [

{
  "id": "weigh_edta",
  "title": "Weigh EDTA Crystals",
  "substeps": [

    {
      "id": "place_weighingBottle",
      "task": "Place the weighing bottle on the electronic balance.",
      "instruction": "Drag the weighing bottle onto the balance.",
      "interaction":"dragToTarget",
    "object":"weighingBottle",
    "target":"balance",
    "snap":"balanceSnap",
    "snapDistance":0.45,
      "placementOffset": [0, -0.8, 0],

      "animation": {
        "type": "moveToObject",
        "duration": 800
      },

      "cameraFocus": {
        "target": "balance",
        "duration": 600
      },

      "scene": {
        "show": [
          "balance",
          "weighingBottle"
        ],
        "hide": [
          "flask",
          "funnel",
          "washBottle",
          "beaker",
          "pipette",
          "burette",
          "edtaCrystals"
        ],
        "highlight": [
          "balance"
        ]
      },

      "feedback": {
        "success": "Weighing bottle placed successfully.",
        "failure": "Drag the weighing bottle onto the balance."
      }
    },

    {
      "id": "pour_edta",
      "task": "Transfer EDTA crystals into the weighing bottle.",
      "instruction": "Drag the EDTA bottle onto the weighing bottle.",

      "object": "edtaCrystals",
      "target": "weighingBottle",

      "interaction": "dragToTarget",

      "animation": {
        "type": "pourIntoObject",
        "duration": 1200
      },

      "cameraFocus": {
        "target": "weighingBottle",
        "duration": 600
      },

      "scene": {
        "show": [
          "balance",
          "weighingBottle",
          "edtaCrystals"
        ],
        "highlight": [
          "weighingBottle"
        ]
      },

      "state": {
        "filled": [
          "weighingBottle"
        ],
        "empty": [
          "edtaCrystals"
        ]
      },

      "feedback": {
        "success": "EDTA transferred successfully.",
        "failure": "Transfer the EDTA crystals into the weighing bottle."
      }
    },

    {
      "id": "adjust_weight",
      "task": "Adjust the balance reading to exactly 0.372 g.",
      "instruction": "Move the slider until the balance displays 0.372 g.",

      "object": "balance",

      "interaction": "slider",

      "requiredMass": 0.372,

      "animation": {
        "type": "updateDisplay",
        "duration": 1000
      },

      "cameraFocus": {
        "target": "balance",
        "duration": 500
      },

      "scene": {
        "show": [
          "balance",
          "weighingBottle"
        ],
        "highlight": [
          "balance"
        ]
      },

      "feedback": {
        "success": "Required mass achieved.",
        "failure": "Adjust until the balance reads exactly 0.372 g."
      }
    }

  ]
},

{
  "id": "transfer_flask",
  "title": "Transfer EDTA to Volumetric Flask",

  "substeps": [

    {
      "id": "insert_funnel",

      "task": "Insert the funnel into the volumetric flask.",

      "instruction": "Drag the funnel into the flask.",

      "object": "funnel",
      "target": "flask",

      "interaction": "dragToTarget",

      "animation": {
        "type": "moveToObject",
        "duration": 900
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 600
      },

      "scene": {

        "show": [
          "flask",
          "funnel",
          "weighingBottle"
        ],

        "hide": [
          "balance",
          "washBottle",
          "pipette",
          "burette",
          "beaker"
        ],

        "highlight": [
          "flask"
        ]
      },

      "feedback": {
        "success": "Funnel inserted.",
        "failure": "Insert the funnel into the flask."
      }
    },

    {
      "id": "pour_edta_flask",

      "task": "Transfer EDTA into the flask.",

      "instruction": "Pour the contents through the funnel.",

      "object": "weighingBottle",
      "target": "funnel",

      "interaction": "dragToTarget",

      "animation": {
        "type": "pourIntoObject",
        "duration": 1500
      },

      "cameraFocus": {
        "target": "funnel",
        "duration": 600
      },

      "scene": {

        "show": [
          "flask",
          "funnel",
          "weighingBottle"
        ],

        "highlight": [
          "funnel"
        ]
      },

      "state": {

        "filled": [
          "flask"
        ],

        "empty": [
          "weighingBottle"
        ]
      },

      "feedback": {
        "success": "EDTA transferred.",
        "failure": "Pour the EDTA into the flask."
      }
    },

    {
      "id": "remove_funnel",

      "task": "Remove the funnel.",

      "instruction": "Drag the funnel away from the flask.",

      "object": "funnel",

      "interaction": "dragAway",

      "animation": {
        "type": "removeObject",
        "duration": 700
      },

      "cameraFocus": {
        "target": "funnel",
        "duration": 500
      },

      "scene": {

        "show": [
          "flask",
          "funnel"
        ]
      },

      "feedback": {
        "success": "Funnel removed.",
        "failure": "Remove the funnel."
      }
    }

  ]
},

{
  "id": "prepare_solution",
  "title": "Prepare EDTA Solution",

  "substeps": [

    {
      "id": "fill_half",

      "task": "Fill the flask halfway with distilled water.",

      "instruction": "Pour distilled water into the flask.",

      "object": "washBottle",
      "target": "flask",

      "interaction": "dragToTarget",

      "animation": {
        "type": "pourLiquid",
        "duration": 2000
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 600
      },

      "scene": {

        "show": [
          "washBottle",
          "flask"
        ],

        "highlight": [
          "flask"
        ]
      },

      "feedback": {
        "success": "Water added.",
        "failure": "Pour water into the flask."
      }
    },

    {
      "id": "swirl",

      "task": "Swirl the flask until the EDTA dissolves.",

      "instruction": "Rotate the flask gently.",

      "object": "flask",

      "interaction": "dragRotate",

      "animation": {
        "type": "swirl",
        "duration": 1800
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 500
      },

      "scene": {

        "show": [
          "flask"
        ]
      },

      "feedback": {
        "success": "EDTA dissolved.",
        "failure": "Rotate the flask gently."
      }
    },

    {
      "id": "fill_mark",

      "task": "Fill the flask up to the calibration mark.",

      "instruction": "Continue filling until the mark is reached.",

      "object": "washBottle",
      "target": "flask",

      "interaction": "dragToTarget",

      "animation": {
        "type": "fillToMark",
        "duration": 2200
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 600
      },

      "scene": {

        "show": [
          "washBottle",
          "flask"
        ],

        "highlight": [
          "flask"
        ]
      },

      "feedback": {
        "success": "Calibration mark reached.",
        "failure": "Fill until the calibration mark."
      }
    }

  ]
},

{
  "id": "mix_solution",
  "title": "Mix the Solution",

  "substeps": [

    {
      "id": "close_flask",

      "task": "Close the flask with the stopper.",

      "instruction": "Click the stopper to close the flask.",

      "object": "flask",

      "interaction": "click",

      "animation": {
        "type": "closeStopper",
        "duration": 800
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 500
      },

      "scene": {

        "show": [
          "flask"
        ]
      },

      "feedback": {
        "success": "Flask closed.",
        "failure": "Close the flask."
      }
    },

    {
      "id": "invert",

      "task": "Invert the flask several times to mix the solution.",

      "instruction": "Rotate the flask upside down several times.",

      "object": "flask",

      "interaction": "dragRotate",

      "animation": {
        "type": "invert",
        "duration": 2500
      },

      "cameraFocus": {
        "target": "flask",
        "duration": 500
      },

      "scene": {

        "show": [
          "flask"
        ]
      },

      "feedback": {
        "success": "Solution mixed successfully.",
        "failure": "Invert the flask several times."
      }
    }

  ]
}

]
}
  